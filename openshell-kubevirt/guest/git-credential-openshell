#!/bin/sh
# Git credential helper that returns OpenShell placeholder credentials.
# The proxy resolves placeholders at egress.
#
# Usage in gitconfig:
#   [credential "https://gitlab.example.com"]
#     helper = openshell GITLAB_TOKEN
#   [credential "https://github.com"]
#     helper = openshell GITHUB_TOKEN
KEY="${1:?}"
shift
case "$1" in
  get)
    echo "username=oauth2"
    echo "password=openshell:resolve:env:$KEY"
    ;;
esac
