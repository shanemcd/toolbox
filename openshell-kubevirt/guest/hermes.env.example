_HERMES_FORCE_GITHUB_TOKEN=openshell:resolve:env:GITHUB_TOKEN
_HERMES_FORCE_GH_TOKEN=openshell:resolve:env:GITHUB_TOKEN
# OpenShell inference proxy (Vertex). Literal rewrite token — not a gateway provider key.
ANTHROPIC_API_KEY=sk-OPENSHELL-PROXY-REWRITE
ANTHROPIC_BASE_URL=https://inference.local
# Non-secret Signal daemon URL (safe to bake). Account / allowlists are NOT
# baked: Hermes load_dotenv(override=True) would clobber create --env.
# Pass those at create time (never commit real values):
#   --env "SLACK_ALLOWED_USERS=U…"
#   --env "SIGNAL_ACCOUNT=+1…"
#   --env "SIGNAL_ALLOWED_USERS=+1…"
SIGNAL_HTTP_URL=http://signal-cli.default.svc.cluster.local:8080
PATH=/opt/hermes/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
